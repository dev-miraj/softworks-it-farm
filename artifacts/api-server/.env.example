# ============================================================
# SOFTWORKS IT FARM — API Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (Neon PostgreSQL) ────────────────────────────
NEON_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── OpenAI (for AI Chat feature) ─────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional: override which model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Security ──────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-64-char-string

# ── Auto Calling System ───────────────────────────────────
# Your deployed API server's public URL (used to generate call links)
PUBLIC_API_URL=https://your-api.railway.app
# Your frontend site URL (call link redirects here)
PUBLIC_FRONTEND_URL=https://softworksit.vercel.app

# ── License Signing ───────────────────────────────────────
LICENSE_SIGNING_SECRET=sw-license-secret-key-2024

# ── E-Commerce Integration API Key ────────────────────────
ECOMMERCE_API_KEY=swec-d587e1c6760bf65438cae1fe80724145c98c0069
