modules = ["nodejs-20", "web", "php-8.2", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Auto Push to GitHub"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/github-push.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Auto Push to GitHub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/github-watch.mjs"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21645
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NEON_DATABASE_URL = "postgresql://neondb_owner:npg_LG3gZFBoT6rt@ep-flat-frog-amjifzm2-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"

[userenv.development]
NODE_ENV = "development"

[userenv.production]
NODE_ENV = "production"
