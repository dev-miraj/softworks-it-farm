FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@10

WORKDIR /app

FROM base AS builder
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY artifacts/softworks/package.json ./artifacts/softworks/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY lib/api-spec/package.json ./lib/api-spec/ 2>/dev/null || true

RUN pnpm install --no-frozen-lockfile

COPY lib/ ./lib/
COPY artifacts/softworks/ ./artifacts/softworks/

ARG VITE_API_URL=""
ENV VITE_API_URL=${VITE_API_URL}

RUN pnpm --filter @workspace/softworks run build

FROM nginx:alpine AS runner
COPY --from=builder /app/artifacts/softworks/dist/public /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost/health-check || exit 1

CMD ["nginx", "-g", "daemon off;"]
