# ============================================
# SOFTWORKS IT FARM — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# The .env file is git-ignored and must NOT be committed.
#
# SAME DATABASE is used for both localhost & production.
# For production (Vercel): set these in Vercel Dashboard > Settings > Environment Variables

# PostgreSQL (Neon) — shared between localhost & production
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Server port (local dev only — Vercel ignores this)
PORT=8080

# Session secret (required for admin auth)
SESSION_SECRET=your-session-secret-here

# Node environment
NODE_ENV=development
