# ============================================================
# SOFTWORKS IT FARM — Environment Variables Template
# ============================================================
# এই ফাইলটি copy করে artifacts/api-server/.env নামে রাখুন
# .env ফাইল git-এ commit করবেন না — .gitignore দ্বারা protected

# ── Database ──────────────────────────────────────────────
# Local / Replit PostgreSQL (Replit এ auto-inject হয়)
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable
PGHOST=helium
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-pg-password
PGDATABASE=heliumdb

# Neon PostgreSQL (Vercel / Production এর জন্য)
# NEON_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Security ──────────────────────────────────────────────
# যেকোনো random string দিন — session signing এর জন্য
SESSION_SECRET=your-random-secret-here

# ── License System ────────────────────────────────────────
# HMAC-SHA256 signing এর জন্য — পরিবর্তন করলে সব validate invalidate হবে!
LICENSE_SIGNING_SECRET=sw-license-secret-key-2024

# ── E-Commerce Integration ────────────────────────────────
# E-commerce সাইট থেকে license provision করার API key
# Header: Authorization: Bearer <key>  অথবা  X-Api-Key: <key>
ECOMMERCE_API_KEY=your-ecommerce-api-key-here
