# ============================================================
# SOFTWORKS IT FARM — Environment Variables Template
# ============================================================
# এই ফাইলটি copy করে .env নামে রাখুন
# .env ফাইল কখনো git-এ commit করবেন না — .gitignore দ্বারা protected

# ── Database ──────────────────────────────────────────────
# Neon PostgreSQL (Vercel / Production এর জন্য)
NEON_DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.neon.tech/neondb?sslmode=require

# Standard PostgreSQL (Docker/VPS এর জন্য)
DATABASE_URL=postgresql://postgres:password@localhost:5432/softworks

# ── JWT Authentication (MANDATORY in production) ──────────
# Strong secret generate করুন:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-64-chars-minimum

# ── Admin Credentials ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Softworks@2024

# ── CORS (comma-separated allowed origins) ────────────────
ALLOWED_ORIGINS=https://softworksit.vercel.app,https://yourdomain.com

# ── Frontend (only needed if API and frontend are on different domains) ──
# Leave empty for same-origin deployment (Railway/Render unified)
VITE_API_URL=

# ── Server ────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Security ──────────────────────────────────────────────
SESSION_SECRET=your-random-secret-here

# ── License System ────────────────────────────────────────
LICENSE_SIGNING_SECRET=sw-license-secret-key-2024

# ── E-Commerce Integration ────────────────────────────────
ECOMMERCE_API_KEY=your-ecommerce-api-key-here
