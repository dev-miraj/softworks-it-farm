{
  "name": "softworks-it-farm",
  "version": "1.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; true'",
    "postinstall": "sh -c 'case \"$npm_config_user_agent\" in npm/*) echo \"Installing workspace packages with pnpm...\" && pnpm install --no-frozen-lockfile || echo \"\\nPlease install pnpm first: npm install -g pnpm\" ;; esac'",
    "install:all": "pnpm install --no-frozen-lockfile",
    "dev": "concurrently --kill-others --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/softworks run dev\"",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/softworks run dev",
    "build": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/softworks run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:web": "pnpm --filter @workspace/softworks run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "typecheck": "pnpm -r --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push-force",
    "db:seed": "npx tsx lib/db/src/seed-vercel.ts",
    "db:reset": "npx tsx lib/db/src/seed.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "prettier": "^3.8.1",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.3.0"
  }
}
