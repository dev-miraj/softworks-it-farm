{
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "node scripts/build-vercel.mjs",
  "outputDirectory": "artifacts/softworks/dist/public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
